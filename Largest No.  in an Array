#include <stdio.h>

int main() {
    int size, i;
    // Prompt user for the size of the array
    printf("Enter the number of elements in the array: ");
    scanf("%d", &size);

    // Declare an array of the specified size
    int array[size];

    // Prompt user to enter elements of the array
    printf("Enter the elements of the array:\n");
    for (i = 0; i < size; i++) {
        printf("Element %d: ", i + 1);
        scanf("%d", &array[i]);
    }

    // Initialize the largest variable with the first element of the array
    int largest = array[0];

    // Iterate through the array starting from the second element
    for (i = 1; i < size; i++) {
        // If the current element is greater than the current largest, update largest
        if (array[i] > largest) {
            largest = array[i];
        }
    }

    // Print the largest element
    printf("The largest element in the array is: %d\n", largest);

    return 0;
}
