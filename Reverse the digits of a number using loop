#include <stdio.h>

int main() {
    int n, reversed_number = 0, remainder;

    printf("Enter an integer: ");
    // The scanf function reads the input provided by the user
    scanf("%d", &n);

    // Loop continues until n becomes 0
    while (n != 0) {
        remainder = n % 10; // Get the last digit
        reversed_number = reversed_number * 10 + remainder; // Append the digit to the reversed number
        n /= 10; // Remove the last digit from the original number
    }

    printf("Reversed number: %d\n", reversed_number);

    return 0;
}
